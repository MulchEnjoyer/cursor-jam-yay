# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/phantom_voice_notes?schema=public"

# Vercel Blob
# Docs: https://www.vercel.com/docs/vercel-blob
# Used by `@vercel/blob` server-side uploads.
BLOB_READ_WRITE_TOKEN="<vercel_blob_read_write_token>"

# Gemini Flash (audio -> transcript + insights)
GEMINI_API_KEY="<gemini_api_key>"
GEMINI_MODEL="gemini-1.5-flash"
GEMINI_AUDIO_MIME_TYPE="audio/webm"

# Internal queueing (used to call the /transcribe/run endpoint)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

